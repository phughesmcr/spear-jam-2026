{
  "description": "Entry for 30 Days of RPG Adventures #1: Spear of Destiny",
  "version": "0.0.1",
  "license": "MIT",
  "unstable": ["tsgo"],
  "nodeModulesDir": "manual",
  "tasks": {
    "check": "export CI=1 && deno task audio:check && deno fmt --check . && deno lint . && deno check && deno test --allow-read=src,tests",
    "audio:generate": "deno run -A scripts/audio_assets.ts generate",
    "audio:check": "deno run -A scripts/audio_assets.ts check",
    "dev": "vite",
    "build": "vite build",
    "build:itch": "deno run -A scripts/itch.ts",
    "preview:itch": "deno run -A npm:vite preview --config vite.itch.config.ts --host",
    "images:optimize": "deno run -A scripts/optimize_images.ts",
    "start": "deno serve -A _fresh/server.js",
    "update": "deno run -A -r jsr:@fresh/update ."
  },
  "lint": {
    "rules": {
      "tags": [
        "fresh",
        "recommended"
      ]
    },
    "include": [
      "default-param-last",
      "explicit-function-return-type",
      "explicit-module-boundary-types",
      "no-await-in-sync-fn",
      "no-const-assign",
      "no-eval",
      "no-non-null-asserted-optional-chain",
      "no-sync-fn-in-async-fn",
      "no-throw-literal",
      "no-top-level-await",
      "no-undef",
      "no-useless-rename",
      "prefer-ascii",
      "single-var-declarator"
    ],
    "exclude": ["*.md", "**/*.md", "LICENSE"]
  },
  "exclude": [
    "**/_fresh/*"
  ],
  "imports": {
    "@/": "./",
    "@std/path": "jsr:@std/path@^1.1.6",
    "turn-based-engine/crawler": "../turn-based-engine/src/crawler/mod.ts",
    "turn-based-engine/ecs": "../turn-based-engine/src/ecs/mod.ts",
    "turn-based-engine/simulation": "../turn-based-engine/src/simulation/mod.ts",
    "@std/assert": "jsr:@std/assert@^1.0.13",
    "fresh": "jsr:@fresh/core@^2.3.3",
    "preact": "npm:preact@^10.29.1",
    "@preact/signals": "npm:@preact/signals@^2.9.0",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.1.2",
    "preact-render-to-string": "npm:preact-render-to-string@^6.7.0",
    "vite": "npm:vite@^7.1.3",
    "@types/babel__core": "npm:@types/babel__core@^7.20.5",
    "zod": "npm:zod@^4.4.3"
  },
  "test": {
    "include": [
      "tests/**/*.test.ts"
    ]
  },
  "compilerOptions": {
    "erasableSyntaxOnly": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "lib": [
      "esnext",
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns"
    ],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": [
      "vite/client"
    ]
  },
  "fmt": {
    "bracePosition": "sameLine",
    "indentWidth": 2,
    "lineWidth": 120,
    "newLineKind": "lf",
    "nextControlFlowPosition": "sameLine",
    "operatorPosition": "sameLine",
    "proseWrap": "always",
    "quoteProps": "consistent",
    "semiColons": true,
    "singleQuote": false,
    "trailingCommas": "onlyMultiLine",
    "useBraces": "whenNotSingleLine",
    "useTabs": false,
    "exclude": ["*.md", "**/*.md", "LICENSE", "src/game/content/maps/*.json"]
  }
}
